# Bottega Environment Configuration
# Only includes variables that are actually used in the code
#
# TIP: Run 'cloudcli status' to see where this file should be located
#      and to view your current configuration.
#
# Available CLI commands:
#   bottega           - Start the server (default)
#   cloudcli start    - Start the server
#   cloudcli status   - Show configuration and data locations
#   cloudcli help     - Show help information
#   cloudcli version  - Show version information

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================

# Backend server port (Express API + WebSocket server)
#API server
PORT=3001
#Frontend port
VITE_PORT=5173

# Hostnames allowed to reach the Vite dev server (in addition to localhost).
# Comma-separated. Required when running behind a reverse proxy on a public
# domain. Leave unset for purely local development.
# VITE_ALLOWED_HOSTS=app.example.com,staging.example.com

# Uncomment the following line if you have a custom claude cli path other than the default "claude"
# CLAUDE_CLI_PATH=claude

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# Path to the authentication database file
# This is where user credentials, API keys, and tokens are stored.
#
# To use a custom location:
# DATABASE_PATH=/path/to/your/custom/auth.db
#
# Claude Code context window size is detected dynamically from the SDK response.
# The [1m] suffix on the model (e.g. claude-opus-4-6[1m]) enables the 1M context window.
# No manual configuration needed — the SDK inherits the CLI default model.

# Root directory where per-user Claude OAuth tokens are stored.
# Defaults to ~/.config/bottega/users (created automatically on first login).
# Override for server/daemon deployments that use a shared system path.
# CLAUDE_CONFIG_ROOT=/var/lib/bottega/users

# =============================================================================
# AUTH SECRETS
# =============================================================================

# Secret used to sign and verify session JWTs. REQUIRED — the server refuses
# to start without it. Generate with: openssl rand -hex 64
# Rotate to invalidate every issued token (forces all users to log in again).
JWT_SECRET=

# Per-IP login throttle (failed attempts; successful logins are not counted).
# Defaults: 20 attempts per 15 min. Tune without redeploying if needed.
# LOGIN_RATE_LIMIT_MAX=20
# LOGIN_RATE_LIMIT_WINDOW_MIN=15

# =============================================================================
# TESTING / AGENT AUTHENTICATION
# =============================================================================

# Auth token for bypassing login (for testing and coding agents)
# Generate a secure token with: openssl rand -hex 32
# Use by appending ?token=<AUTH_TOKEN> to any URL
# AUTH_TOKEN=your-secure-token-here

# =============================================================================
# OPENAI (VOICE TRANSCRIPTION)
# =============================================================================

# Used by server/services/transcription.ts for the chat input mic feature.
# Without it, transcription requests return "OpenAI API key not configured".
# OPENAI_API_KEY=sk-proj-your-key-here

# =============================================================================
# PUSH NOTIFICATIONS (OneSignal)
# =============================================================================

# OneSignal App ID (same as iOS app)
# ONESIGNAL_APP_ID=your_onesignal_app_id

# OneSignal REST API Key (from OneSignal dashboard > Settings > Keys & IDs)
# ONESIGNAL_REST_API_KEY=your_rest_api_key

# =============================================================================
# GITHUB WEBHOOK CONFIGURATION
# =============================================================================

# Secret for validating GitHub webhook signatures
# Generate with: openssl rand -hex 32
# Configure this same value in your GitHub repo's webhook settings
# GITHUB_WEBHOOK_SECRET=your-webhook-secret-here
