{
  "name": "bottega",
  "version": "1.12.0",
  "description": "Bottega",
  "type": "module",
  "packageManager": "pnpm@11.0.9",
  "main": "server/index.ts",
  "bin": {
    "bottega": "server/cli.ts",
    "cloudcli": "server/cli.ts"
  },
  "files": [
    "server/",
    "src/",
    "shared/",
    "README.md"
  ],
  "homepage": "https://github.com/vdaubry/bottega",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vdaubry/bottega.git"
  },
  "bugs": {
    "url": "https://github.com/vdaubry/bottega/issues"
  },
  "scripts": {
    "check-env": "tsx scripts/check-env.ts",
    "predev": "pnpm check-env",
    "preserver": "pnpm check-env",
    "dev": "concurrently --kill-others \"pnpm run server\" \"pnpm run client\"",
    "server": "tsx server/index.ts",
    "client": "vite --host",
    "create-user": "tsx scripts/create-user.ts",
    "onboarding": "tsx scripts/onboarding.ts",
    "test-notification": "tsx scripts/test-notification.ts",
    "test-badge": "tsx scripts/test-badge.ts",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "guard-no-js": "tsx scripts/guard-no-js.ts",
    "prelint": "pnpm guard-no-js",
    "lint": "eslint ."
  },
  "keywords": [
    "claude coode",
    "ai",
    "anthropic",
    "ui",
    "mobile"
  ],
  "author": "Vincent Daubry",
  "license": "MIT",
